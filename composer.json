{
    "name": "ministry-cooperatives/desahub",
    "type": "project",
    "description": "DesaHub — B2B Village Commodity Aggregator & Pre-Order Contract Web Application for Ministry of Cooperatives Hackathon",
    "keywords": [
        "laravel",
        "filament",
        "inertia",
        "vue",
        "b2b",
        "cooperative",
        "hackathon"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "^3.2",
        "inertiajs/inertia-laravel": "^1.0",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}